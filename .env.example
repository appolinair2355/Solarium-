# ─────────────────────────────────────────────────────────────────
#  BACCARAT PRO — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────────────

# ── PORT ─────────────────────────────────────────────────────────
# Render   : imposez 10000
# Railway  : laissez vide (Railway injecte PORT automatiquement)
# Heroku   : laissez vide (Heroku injecte PORT automatiquement)
# VPS/Solo : 3000 ou toute valeur libre
PORT=3000

# ── Environnement ────────────────────────────────────────────────
NODE_ENV=production

# ── Clé secrète de session ───────────────────────────────────────
# Chaîne aléatoire longue (min 32 caractères)
SESSION_SECRET=changez_moi_par_une_longue_chaine_aleatoire_32chars

# ── Base de données PostgreSQL (OPTIONNEL) ───────────────────────
# Si absent → mode JSON local (data/db.json), aucune DB requise
# DATABASE_URL=postgres://user:password@host:5432/baccarat_db

# ── Telegram (OPTIONNEL — configurable aussi dans le panneau admin) ──
# BOT_TOKEN=votre_token_bot_telegram
